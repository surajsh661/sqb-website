# Copy this file to ".env.local" and fill in real values.
# Never commit .env.local — it's gitignored on purpose.

# Resend API key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Where brief submissions are emailed.
CONTACT_TO=hello@sqbpictures.com

# "From" address shown on the email — must be a domain you've verified
# in Resend, or use onboarding@resend.dev for testing.
CONTACT_FROM=S'QB Site <onboarding@resend.dev>
